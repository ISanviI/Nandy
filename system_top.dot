digraph "multiply" {
label="multiply";
rankdir="LR";
remincross=true;
n1 [ shape=diamond, label="state", color="black", fontcolor="black"];
n2 [ shape=octagon, label="start", color="black", fontcolor="black"];
n3 [ shape=octagon, label="rst", color="black", fontcolor="black"];
n4 [ shape=octagon, label="req_alu", color="black", fontcolor="black"];
